{
    "manifest_version": 3,
    "name": "WhatsApp CRM Extension",
    "version": "1.0.0",
    "action": {
        "default_popup": "index.html"
    },
    "content_scripts": [
        {
            "js": [
                "src/content/index.tsx"
            ],
            "matches": [
                "https://web.whatsapp.com/*"
            ],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "src/background/index.ts",
        "type": "module"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "injected.js",
                "wppconnect.js"
            ],
            "matches": [
                "https://web.whatsapp.com/*"
            ]
        }
    ],
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://web.whatsapp.com/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
    ]
}