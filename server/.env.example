# =============================================
# VARIÁVEIS DE AMBIENTE - CRM Ivillar
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no Git
# =============================================

# JWT - OBRIGATÓRIO - Use no mínimo 32 caracteres aleatórios
# Gere um com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Senha para o endpoint de reset de banco - OBRIGATÓRIO para usar o endpoint
# Use uma senha forte (20+ caracteres)
ADMIN_RESET_PASSWORD=

# ConvertAPI - Chave de acesso (obtenha em https://www.convertapi.com/)
CONVERT_API_SECRET=

# URL do banco de dados (SQLite por padrão)
DATABASE_URL=file:./dev.db

# Porta do servidor (padrão: 3001)
PORT=3001

# Ambiente: development | production
NODE_ENV=development

# Origins permitidos pelo CORS (separados por vírgula)
# Exemplos: http://localhost:5173,https://meudominio.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# OAuth - Meta (Facebook/Instagram)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# OAuth - LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
